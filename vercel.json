{
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 8 * * *"
    }
  ],
  "functions": {
    "app/api/sync/route.ts": {
      "maxDuration": 60
    },
    "app/api/sync/gmail/route.ts": {
      "maxDuration": 30
    },
    "app/api/sync/slack/route.ts": {
      "maxDuration": 30
    },
    "app/api/cron/route.ts": {
      "maxDuration": 60
    }
  }
}
